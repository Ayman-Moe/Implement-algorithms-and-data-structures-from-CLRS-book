# Ensure consistent line endings across platforms
* text=auto eol=lf

# Explicitly enforce line endings for specific file types
*.ps1 text eol=crlf      # PowerShell scripts (Windows)
*.sh  text eol=lf        # Shell scripts (Unix)
*.cpp text eol=lf
*.h   text eol=lf
*.rs  text eol=lf
*.md  text eol=lf

# Treat docs as text
*.txt text
*.md  text

# Binary files (no line ending conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.exe binary
*.dll binary